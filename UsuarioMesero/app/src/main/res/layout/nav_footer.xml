<?xml version="1.0" encoding="utf-8"?>
<!--
    Pie del Menú Lateral (Navigation Drawer).
    Muestra la información del usuario en la parte inferior.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Separador visual -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/white"
        android:alpha="0.2"
        android:layout_marginBottom="24dp"/>

    <!-- Sección de Perfil -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Avatar con iniciales -->
        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/terracota_rojizo"
            android:gravity="center"
            android:text="HG"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_user_name_footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_name_full"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_role"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.7" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>