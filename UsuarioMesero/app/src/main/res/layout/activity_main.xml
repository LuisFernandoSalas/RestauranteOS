<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout para el Login del Mesero (MODO TABLET - sw600dp).
    Diseño de panel dividido (Split View) optimizado para pantallas grandes.
    Incluye el formulario modularizado para mantener consistencia.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- PANEL IZQUIERDO: Información del Sistema (Color Terracota) -->
    <View
        android:id="@+id/panel_izquierdo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/terracota_oscuro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guía vertical para dividir la pantalla (40% - 60%) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4" />

    <!-- Contenido del Panel Izquierdo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_restricted"
        app:layout_constraintEnd_toEndOf="@id/panel_izquierdo"
        app:layout_constraintStart_toStartOf="@id/panel_izquierdo"
        app:layout_constraintTop_toTopOf="@id/panel_izquierdo">

        <!-- Espacio para el Logo -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_circle"
            android:padding="20dp">

            <ImageView
                android:id="@+id/iv_logo_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Logo"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="@color/crema" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/header_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/module_name"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/system_description"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="italic"
            android:alpha="0.7" />
    </LinearLayout>

    <!-- Footer de Acceso Restringido en Panel Izquierdo -->
    <LinearLayout
        android:id="@+id/layout_restricted"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="#33000000"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="@id/panel_izquierdo"
        app:layout_constraintEnd_toEndOf="@id/panel_izquierdo"
        app:layout_constraintStart_toStartOf="@id/panel_izquierdo">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="#4CAF50" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/restricted_access_title"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/restricted_access_subtitle"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>


    <!-- PANEL DERECHO: Formulario (Color Crema) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_derecho"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/crema"
        android:padding="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_welcome_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textColor="@color/terracota_oscuro"
            android:textSize="40sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/welcome_subtitle"
            android:textColor="@color/terracota_medio"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_right" />

        <!-- Formulario Modularizado -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle_right"
            app:layout_constraintVertical_bias="0.3">

            <include layout="@layout/layout_login_form" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>