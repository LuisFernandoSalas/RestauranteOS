<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Icono de Candado Verde -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/security_icon_desc"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="#1B5E20" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvForgotTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/dialog_forgot_title"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/dialog_forgot_subtitle"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp" />

        <!-- Etiqueta Código -->
        <TextView
            android:id="@+id/labelCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:labelFor="@+id/etRecoveryCode"
            android:text="@string/label_code"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp" />

        <!-- Input de Código (Fondo Negro) -->
        <EditText
            android:id="@+id/etRecoveryCode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="4dp"
            android:autofillHints="password"
            android:background="@drawable/edittext_background"
            android:gravity="center"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <!-- Botón Verificar -->
        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/terracotta_dark"
            android:text="@string/button_verify"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <!-- Botón Cancelar -->
        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/button_cancel"
            android:textAllCaps="false"
            android:textColor="@android:color/darker_gray"
            app:strokeColor="@android:color/darker_gray" />

    </LinearLayout>
</androidx.cardview.widget.CardView>