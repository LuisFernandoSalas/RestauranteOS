<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout para el Fragmento de Login.
    Utiliza ConstraintLayout para posicionar los elementos de forma flexible.
    Diseñado para ajustarse sin scroll en la mayoría de dispositivos.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_background"
    tools:context=".FragmentoLogin">

    <!-- Logo de la aplicación: Centrado superior -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="265dp"
        android:layout_height="209dp"
        android:layout_marginTop="@dimen/login_top_margin"
        android:contentDescription="@string/app_name"
        android:scaleType="centerInside"
        android:src="@drawable/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Título principal: Estilo Negrita y color Oro -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/login_title"
        android:textColor="@color/orange_gold"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogo" />

    <!-- Subtítulo informativo -->
    <TextView
        android:id="@+id/txtSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/login_subtitle"
        android:textColor="@color/burnt_orange"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

    <!-- Etiqueta para el campo de Usuario -->
    <TextView
        android:id="@+id/lblUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/label_user"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/txtUsuario"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitulo" />

    <!-- Campo de entrada para Usuario -->
    <EditText
        android:id="@+id/txtUsuario"
        android:layout_width="0dp"
        android:layout_height="@dimen/input_height"
        android:layout_marginHorizontal="@dimen/login_horizontal_margin"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_input_field"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:textColor="@color/white"
        android:autofillHints="username"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lblUsuario"
        app:layout_constraintWidth_max="500dp" />

    <!-- Etiqueta para el campo de Contraseña -->
    <TextView
        android:id="@+id/lblContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/label_password"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/txtContrasena"
        app:layout_constraintTop_toBottomOf="@id/txtUsuario" />

    <!-- Campo de entrada para Contraseña -->
    <EditText
        android:id="@+id/txtContrasena"
        android:layout_width="0dp"
        android:layout_height="@dimen/input_height"
        android:layout_marginHorizontal="@dimen/login_horizontal_margin"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_input_field"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:textColor="@color/white"
        android:autofillHints="password"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lblContrasena"
        app:layout_constraintWidth_max="500dp" />

    <!-- Enlace de recuperación: Alineado a la derecha del campo de contraseña -->
    <TextView
        android:id="@+id/txtOlvideContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/forgot_password"
        android:textColor="@color/burnt_orange"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@id/txtContrasena"
        app:layout_constraintTop_toBottomOf="@id/txtContrasena" />

    <!-- Botón de Ingreso: Acción principal -->
    <Button
        android:id="@+id/btnIngresar"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/login_horizontal_margin"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_button"
        android:text="@string/btn_login"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtOlvideContrasena"
        app:layout_constraintWidth_max="500dp" />

</androidx.constraintlayout.widget.ConstraintLayout>